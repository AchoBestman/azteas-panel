# ============================================================
# AZTEAS PANEL - Variables d'environnement globales
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter le fichier .env
# ============================================================

# ---- Domaine principal ----
DOMAIN=azteas.com

# ---- VPS ----
VPS_HOST=
VPS_USER=
VPS_PORT=

# ---- Traefik ----
TRAEFIK_DASHBOARD_USER=        # format : user:password_hash (htpasswd)
ACME_EMAIL=                    # email pour Let's Encrypt

# ---- Hetzner Storage Box ----
STORAGEBOX_HOST=
STORAGEBOX_USER=
STORAGEBOX_PASSWORD=
STORAGEBOX_SHARE=

# ---- Backblaze B2 ----
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET=

# ---- MariaDB ----
MARIADB_ROOT_PASSWORD=
MARIADB_USER=
MARIADB_PASSWORD=

# ---- PostgreSQL ----
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---- MongoDB ----
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# ---- Redis ----
REDIS_PASSWORD=

# ---- Piler ----
PILER_MYSQL_PASSWORD=
PILER_ARCHIVE_HOST=archive.azteas.com
PILER_SMTP_PORT=25
