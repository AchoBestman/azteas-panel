# ============================================================
# AZTEAS PANEL - Référence globale des variables d'environnement
#
# Ce fichier est une DOCUMENTATION de référence uniquement.
# Chaque service possède son propre .env.example autonome.
# Les scripts sourcent uniquement le .env de leur service.
#
# Ne jamais commiter un fichier .env
# ============================================================

# ---- Domaine principal ----
DOMAIN=azteas.com

# ---- VPS ----
VPS_HOST=                      # IP publique du VPS Contabo
SSH_PORT=1995                  # port SSH personnalisé (utilisé par fail2ban)

# ---- SMTP (pour fail2ban et alertes système) ----
SMTP_HOST=                     # serveur SMTP (ex: mail.azteas.com)
SMTP_PORT=587                  # 587 = STARTTLS, 465 = TLS implicite
SMTP_USER=                     # utilisateur SMTP
SMTP_PASSWORD=                 # mot de passe SMTP
SMTP_FROM=noreply@azteas.com   # expéditeur des alertes
ADMIN_EMAIL=admin@azteas.com   # destinataire des alertes
VPS_USER=                      # utilisateur non-root avec sudo
VPS_PORT=                      # port SSH personnalisé (ex: 1995)

# ---- Timezone ----
TZ=Europe/Paris                # timezone du serveur

# ---- Notifications ----
ADMIN_EMAIL=admin@azteas.com   # destinataire des alertes d'échec de backup

# ============================================================
# TRAEFIK
# ============================================================

ACME_EMAIL=admin@azteas.com    # email pour Let's Encrypt (notifications expiration)
TRAEFIK_DASHBOARD_AUTH=        # hash htpasswd généré par setup.sh (ne pas remplir manuellement)
CF_DNS_API_TOKEN=              # token API Cloudflare (Zone:DNS:Edit sur azteas.com)
                               # générer sur : https://dash.cloudflare.com/profile/api-tokens

# ============================================================
# HETZNER STORAGE BOX
# ============================================================

STORAGEBOX_HOST=               # ex: uXXXXXX.your-storagebox.de
STORAGEBOX_USER=               # ex: uXXXXXX
STORAGEBOX_PASSWORD=           # mot de passe Storage Box
STORAGEBOX_SHARE=              # nom du partage CIFS (ex: /backup)

# ============================================================
# BACKBLAZE B2
# ============================================================

B2_ACCOUNT_ID=                 # ID du compte Backblaze B2
B2_APPLICATION_KEY=            # clé d'application Backblaze B2
B2_BUCKET=                     # nom du bucket B2 (ex: azteas-backups)

# ============================================================
# RESTIC - Mots de passe de chiffrement (un par service)
# ⚠️  Conserver précieusement — sans eux la restauration est impossible
# ============================================================

RESTIC_MAILCOW_PASSWORD=       # mot de passe chiffrement backup Mailcow
RESTIC_PILER_PASSWORD=         # mot de passe chiffrement backup Piler

# ============================================================
# MAILCOW
# ============================================================

MAILCOW_HOSTNAME=mail.azteas.com  # FQDN du serveur mail
MAILCOW_TZ=Europe/Paris           # timezone Mailcow

# Ports internes (Traefik gère 80/443 — ne pas modifier)
HTTP_PORT=8080
HTTPS_PORT=8443

# Désactiver SSL interne (Traefik gère les certificats)
SKIP_LETS_ENCRYPT=y
SKIP_HTTP_VERIFICATION=y
AUTODISCOVER_SAN=n
ENABLE_IPV6=false

# Mots de passe base de données Mailcow (générés par generate_config.sh)
DBPASS=                        # généré automatiquement par setup.sh
DBROOT=                        # généré automatiquement par setup.sh
REDISPASS=                     # généré automatiquement par setup.sh

# ============================================================
# PILER
# ============================================================

PILER_MYSQL_PASSWORD=          # mot de passe base de données Piler
PILER_ARCHIVE_HOST=archive.azteas.com  # domaine public de Piler
PILER_SMTP_PORT=25             # port SMTP Piler (25 en prod, 2526 en test)

# ============================================================
# MARIADB (service standalone)
# ============================================================

MARIADB_ROOT_PASSWORD=
MARIADB_USER=
MARIADB_PASSWORD=

# ============================================================
# POSTGRESQL
# ============================================================

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ============================================================
# MONGODB
# ============================================================

MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# ============================================================
# REDIS (service standalone)
# ============================================================

REDIS_PASSWORD=
