# ============================================================
# MAIL (msmtp) - Variables d'environnement
# ============================================================
#
# Ces variables sont lues depuis /opt/azteas-panel/.env sur le VPS.
# Elles ne sont PAS dans un .env propre au dossier mail/.
#
# Ajouter ces variables dans /opt/azteas-panel/.env avant de
# lancer setup-mail.sh :
#
#   nano /opt/azteas-panel/.env
# ============================================================

# ---- Serveur SMTP sortant pour les notifications internes ----
SMTP_HOST="mail.azteas.com"       # serveur SMTP (ex: mail.azteas.com)
SMTP_PORT=465                   # 587 = STARTTLS, 465 = TLS implicite
SMTP_USER=""    # utilisateur SMTP (ex: noreply@azteas.com)
SMTP_PASSWORD=""                  # mot de passe SMTP (secret)
SMTP_FROM="noreply@azteas.com"    # adresse expéditeur des alertes
# ---- Destinataire des alertes ----
ADMIN_EMAIL="aikpeachille55@gmail.com"   # reçoit les alertes fail2ban et backup

# ---- SSH ----
VPS_PORT=                   # port SSH du VPS (utilisé par fail2ban)

