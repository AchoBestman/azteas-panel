# ============================================================
# Traefik - Variables d'environnement
# Copier en .env et remplir les valeurs réelles
# Ne jamais commiter .env
# ============================================================

# Email pour Let's Encrypt (notifications expiration certificats)
ACME_EMAIL=admin@azteas.com

# Authentification dashboard Traefik.
# Générer avec : htpasswd -nB admin
# Echapper les $ en $$ dans le fichier .env
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$...
