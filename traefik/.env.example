# ============================================================
# TRAEFIK - Variables d'environnement
# ============================================================
#
# Deux approches pour définir ces variables :
#
# 1. AUTOMATIQUE (recommandé) : définir sur GitHub et lancer le build
#    - Secrets GitHub (Settings → Secrets → Actions) :
#        CF_DNS_API_TOKEN, TRAEFIK_DASHBOARD_AUTH
#    - Variables GitHub (Settings → Variables → Actions) :
#        ACME_EMAIL
#    Le workflow génère ce fichier automatiquement sur le VPS.
#
# 2. MANUEL : copier ce fichier en .env sur le VPS et remplir
#    ssh mailcow
#    cp /opt/azteas-panel/traefik/.env.example /opt/azteas-panel/traefik/.env
#    nano /opt/azteas-panel/traefik/.env
#
# Ne jamais commiter le fichier .env
# ============================================================

# ---- GitHub Variable ----
ACME_EMAIL=admin@azteas.com    # email pour Let's Encrypt

# ---- GitHub Secrets ----
CF_DNS_API_TOKEN=              # token API Cloudflare (Zone:DNS:Edit sur azteas.com)
                               # générer sur : https://dash.cloudflare.com/profile/api-tokens

TRAEFIK_DASHBOARD_AUTH=        # hash bcrypt généré par setup.sh
                               # format : user:$$2y$$...
                               # générer avec : htpasswd -nbB admin MON_MOT_DE_PASSE
