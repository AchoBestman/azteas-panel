# ============================================================
# COOLIFY - Variables d'environnement
# ============================================================
#
# Secrets GitHub :
#   COOLIFY_APP_KEY     → générer : php -r "echo 'base64:'.base64_encode(random_bytes(32));"
#   COOLIFY_DB_PASSWORD
#   COOLIFY_REDIS_PASSWORD
#
# Variables GitHub :
#   COOLIFY_APP_ID      → générer : openssl rand -hex 16
# ============================================================

# ---- GitHub Variable ----
COOLIFY_APP_ID=              # openssl rand -hex 16

# ---- GitHub Secrets ----
COOLIFY_APP_KEY=             # base64:... (32 bytes encodés base64)
COOLIFY_DB_PASSWORD=
COOLIFY_REDIS_PASSWORD=
