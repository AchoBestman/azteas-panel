# ============================================================
# OPENARCHIVER - Archivage mail légal (Gmail, M365, IMAP générique)
#
# OpenArchiver réutilise les services PARTAGÉS postgresql/ et redis/ de ce
# dépôt (pas de base dédiée). Le stockage des emails (.eml) se fait sur
# Cloudflare R2 (externe, pas Minio — zéro egress, pas de disque VPS à faire
# grossir pour un archive destiné à croître sur des années). Meilisearch
# (recherche) et Tika (extraction de texte des pièces jointes) n'ont pas
# d'équivalent partagé dans ce dépôt et sont donc dédiés, définis
# directement dans openarchiver/docker-compose.yml.
#
# Bucket R2 + token API S3 à créer une fois manuellement dans le dashboard
# Cloudflare avant le premier déploiement (voir README.md).
#
# Deux approches pour définir ces variables :
#
# 1. AUTOMATIQUE (recommandé) : définir sur GitHub et lancer le build
#    - Secrets GitHub dédiés : OPENARCHIVER_DB_PASSWORD,
#                              OPENARCHIVER_R2_ACCESS_KEY_ID,
#                              OPENARCHIVER_R2_SECRET_ACCESS_KEY,
#                              OPENARCHIVER_MEILI_MASTER_KEY,
#                              OPENARCHIVER_JWT_SECRET,
#                              OPENARCHIVER_ENCRYPTION_KEY
#    - Variables GitHub dédiées : ARCHIVE_HOST, VERSION (optionnelle),
#                                 OPENARCHIVER_R2_ACCOUNT_ID,
#                                 OPENARCHIVER_R2_BUCKET (optionnelle)
#    - Secrets/variables globaux réutilisés (déjà définis pour postgresql/,
#      redis/) : POSTGRES_USER, POSTGRES_PASSWORD, REDIS_PASSWORD
#    Le workflow génère ce fichier automatiquement sur le VPS.
#
# 2. MANUEL : copier ce fichier en .env sur le VPS et remplir
#    cp .env.example .env && nano .env
#
# Ne jamais commiter le fichier .env
# ============================================================

# ---- GitHub Variables dédiées ----
ARCHIVE_HOST=openarchiver.azteas.com   # domaine public d'OpenArchiver
VERSION=latest                          # tag de logiclabshq/open-archiver

# ---- Cloudflare R2 (stockage externe managé, pas Minio) ----
OPENARCHIVER_R2_ACCOUNT_ID=        # variable — ID de compte Cloudflare (visible dans l'URL du dashboard R2)
OPENARCHIVER_R2_BUCKET=openarchiver # variable — nom du bucket R2 (créé manuellement au préalable)
OPENARCHIVER_R2_ACCESS_KEY_ID=     # secret — Access Key ID du token API R2 (permissions "Object Read & Write" scopées à ce bucket)
OPENARCHIVER_R2_SECRET_ACCESS_KEY= # secret — Secret Access Key du même token

# ---- GitHub Secrets dédiés ----
OPENARCHIVER_DB_PASSWORD=      # mot de passe du role PostgreSQL dédié "openarchiver" (openssl rand -hex 20)
OPENARCHIVER_MEILI_MASTER_KEY= # clé maître Meilisearch dédiée (openssl rand -hex 32)
OPENARCHIVER_JWT_SECRET=       # signature des tokens d'authentification (openssl rand -base64 32)
OPENARCHIVER_ENCRYPTION_KEY=   # chiffrement des identifiants stockés en base (openssl rand -hex 32)
OPENARCHIVER_SYNC_FREQUENCY=   # optionnel, cron 6 champs, défaut "0 0 */2 * * *" (toutes les 2h)

# ---- Repris des services partagés (mêmes valeurs que postgresql/redis) ----
POSTGRES_USER=
POSTGRES_PASSWORD=
REDIS_PASSWORD=
