# ============================================================
# APANEL — Provisioning des identifiants dédiés
# (l'app elle-même est déployée sur Vercel, pas ici)
#
# Secrets GitHub dédiés : APANEL_DB_PASSWORD, APANEL_REDIS_PASSWORD
#
# Secrets/variables GitHub globaux réutilisés (déjà définis pour
# postgresql/, redis/) :
#   POSTGRES_USER, POSTGRES_PASSWORD, REDIS_PASSWORD
# ===========================================================

# ---- Repris des services partagés (mêmes valeurs que postgresql/redis) ----
POSTGRES_USER=
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ---- Secrets GitHub dédiés à apanel ----
# Générer avec : openssl rand -hex 20
APANEL_DB_PASSWORD=
APANEL_REDIS_PASSWORD=
