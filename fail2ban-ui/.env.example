# ============================================================
# FAIL2BAN-UI - Variables d'environnement
# Image officielle : swissmakers/fail2ban-ui
# https://github.com/swissmakers/fail2ban-ui
#
# Aucun secret obligatoire : sans OIDC, l'UI n'a AUCUNE authentification
# native. L'accès est protégé uniquement par auth-basic@file de Traefik
# (même .htpasswd que le dashboard Traefik) — voir les labels dans docker-compose.yml
# ============================================================

AUTODARK=false                     # variable — dark mode auto selon préférence navigateur
DISABLE_EXTERNAL_IP_LOOKUP=true    # variable — désactive l'appel externe d'affichage IP publique
UPDATE_CHECK=false                 # variable — désactive la vérification de nouvelle version sur GitHub

# ---- Callback interne (optionnel) ----
# Par défaut http://127.0.0.1:8080 — suffisant ici car le port du conteneur
# est publié sur le loopback de l'hôte (voir docker-compose.yml). Ne remplir
# que si le comportement par défaut ne convient pas.
# CALLBACK_URL=
# CALLBACK_SECRET=                 # secret — sinon généré automatiquement au premier démarrage

# ============================================================
# OIDC (optionnel, désactivé par défaut)
# Pas de fournisseur OIDC (Keycloak/Authentik/Pocket-ID) dans cette infra
# aujourd'hui — laisser désactivé et s'appuyer sur auth-basic@file.
# ============================================================
# OIDC_ENABLED=true
# OIDC_PROVIDER=                   # keycloak | authentik | pocketid
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=              # secret
# OIDC_REDIRECT_URL=
