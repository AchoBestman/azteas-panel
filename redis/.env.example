# ============================================================
# REDIS - Variables d'environnement
# Secrets GitHub : REDIS_PASSWORD
# ===========================================================
#
# Redis partagé (16 index logiques disponibles, --databases 16).
# Registre des index déjà réservés pour éviter les collisions entre services :
#   0  → défaut (non utilisé directement par un service en particulier)
#   1  → plane/ (cache, sessions)
# ============================================================

REDIS_PASSWORD=    # secret

# ---- Accès externe via Traefik TCP passthrough (ex: apanel/Vercel) ----
# CN du certificat TLS auto-signé généré par redis-tls-init. Optionnel —
# défaut "redis-tcp.azteas.com" si absent.
REDIS_TLS_CN=redis-tcp.azteas.com   # variable

# Suffixe utilisé pour renommer les commandes dangereuses (FLUSHALL, FLUSHDB,
# CONFIG, KEYS, SHUTDOWN) sur l'instance partagée — à connaître pour toute
# opération de maintenance nécessitant ces commandes.
# Générer avec : openssl rand -hex 8
REDIS_RENAME_SUFFIX=   # secret

# Prérequis VPS (une fois) — le sidecar redis-acl-log-exporter (image
# redis:7-alpine, entrypoint shell custom donc pas de drop de privilège
# garanti vers un user "redis") écrit dans ce dossier ; à défaut de confirmer
# l'UID exact au premier déploiement, le rendre inscriptible largement :
#   sudo mkdir -p /var/log/redis && sudo chmod 777 /var/log/redis
