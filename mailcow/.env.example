# ============================================================
# MAILCOW - Variables d'environnement
# ============================================================
#
# Deux approches pour définir ces variables :
#
# 1. AUTOMATIQUE (recommandé) : définir sur GitHub et lancer le build
#    - Secrets GitHub (Settings → Secrets → Actions) :
#        MAILCOW_B2_ACCOUNT_ID, MAILCOW_B2_APPLICATION_KEY
#        RESTIC_MAILCOW_PASSWORD
#        MAILCOW_DBPASS, MAILCOW_DBROOT, MAILCOW_REDISPASS
#    - Variables GitHub (Settings → Variables → Actions) :
#        MAILCOW_HOSTNAME, TZ, ADMIN_EMAIL, B2_BUCKET
#    Le workflow génère ce fichier automatiquement sur le VPS.
#
# 2. MANUEL : copier ce fichier en .env sur le VPS et remplir
#    ssh mailcow
#    cp /opt/azteas-panel/mailcow/.env.example /opt/azteas-panel/mailcow/.env
#    nano /opt/azteas-panel/mailcow/.env
#
# Ne jamais commiter le fichier .env
# ============================================================

# ---- GitHub Variables (non-sensibles) ----
MAILCOW_HOSTNAME=mail.azteas.com   # FQDN du serveur mail
MAILCOW_TZ=Europe/Paris            # timezone
ADMIN_EMAIL=admin@azteas.com       # destinataire des alertes d'échec de backup
MAILCOW_B2_BUCKET=                 # nom du bucket Backblaze B2 dédié Mailcow

# ---- Valeurs fixes (ne pas modifier) ----
HTTP_PORT=8080
HTTPS_PORT=8443
SKIP_LETS_ENCRYPT=y
SKIP_HTTP_VERIFICATION=y
AUTODISCOVER_SAN=n
ENABLE_IPV6=false

# ---- GitHub Secrets (sensibles) -----
# Les variables suivantes sont générées automatiquement par generate_config.sh
# Ne pas définir manuellement — Mailcow les gère lui-même
# DBPASS=
# DBROOT=
# REDISPASS=

MAILCOW_B2_ACCOUNT_ID=             # ID compte Backblaze B2 dédié Mailcow
MAILCOW_B2_APPLICATION_KEY=        # clé application Backblaze B2 → écrite comme B2_ACCOUNT_KEY dans .env (restic)

# ⚠️  Conserver précieusement — sans ce mot de passe la restauration est impossible
RESTIC_MAILCOW_PASSWORD=                   # mot de passe chiffrement backup Mailcow
# RESTIC_REPOSITORY est généré automatiquement par le workflow : b2:MAILCOW_B2_BUCKET:mailcow
