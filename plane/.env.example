# ============================================================
# PLANE - Gestionnaire de projet (Community Edition, image All-In-One)
#
# Plane utilise les services PARTAGÉS de ce dépôt (pas de base/redis/mq/
# stockage dédiés) : postgresql/, redis/, rabbitmq/, minio/. Les identifiants
# admin de ces services partagés doivent donc aussi être présents ici, en
# plus des identifiants dédiés à Plane.
#
# Secrets GitHub dédiés à Plane :
#   PLANE_DB_PASSWORD, PLANE_RABBITMQ_PASSWORD, PLANE_MINIO_PASSWORD,
#   PLANE_SECRET_KEY, PLANE_LIVE_SECRET_KEY
# Variable GitHub dédiée à Plane :
#   PLANE_VERSION (optionnelle, défaut "stable")
#
# Secrets/variables GitHub globaux réutilisés (déjà définis pour
# postgresql/, redis/, rabbitmq/, minio/) :
#   POSTGRES_USER, POSTGRES_PASSWORD, REDIS_PASSWORD,
#   RABBITMQ_USER, RABBITMQ_PASSWORD, MINIO_ROOT_USER, MINIO_ROOT_PASSWORD
# ============================================================

# ---- GitHub Variable dédiée à Plane ----
PLANE_VERSION=stable          # tag de makeplane/plane-aio-community (stable, v1.3.1, ...)

# ---- GitHub Secrets dédiés à Plane ----
PLANE_DB_PASSWORD=             # mot de passe du role PostgreSQL dédié "plane" (sur l'instance partagée)
PLANE_RABBITMQ_PASSWORD=       # mot de passe du user RabbitMQ dédié "plane" (sur l'instance partagée)
PLANE_MINIO_PASSWORD=          # secret key du user Minio dédié "plane" (sur l'instance partagée)
PLANE_SECRET_KEY=              # openssl rand -hex 32
PLANE_LIVE_SECRET_KEY=         # openssl rand -hex 32 (serveur collaboration temps réel)

# ---- Repris des services partagés (mêmes valeurs que postgresql/redis/rabbitmq/minio) ----
POSTGRES_USER=
POSTGRES_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_USER=
RABBITMQ_PASSWORD=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
