# ============================================================
# POSTGRESQL - Variables d'environnement
# Secrets GitHub : POSTGRES_PASSWORD, PGADMIN_PASSWORD
# Variables GitHub : POSTGRES_USER, POSTGRES_DB, PGADMIN_EMAIL
# ===========================================================

POSTGRES_USER=            # variable
POSTGRES_PASSWORD=        # secret
POSTGRES_DB=postgres      # variable

PGADMIN_EMAIL=            # variable (email de connexion pgAdmin)
PGADMIN_PASSWORD=         # secret

# ---- Accès externe via Traefik TCP passthrough (ex: apanel/Vercel) ----
# CN du certificat TLS auto-signé généré par postgresql-tls-init (voir
# docker-compose.yml). Optionnel — défaut "pg-tcp.azteas.com" si absent.
POSTGRES_TLS_CN=pg-tcp.azteas.com   # variable

# Prérequis VPS (une fois) : le dossier bind-monté pour les logs doit être
# accessible en écriture par l'uid postgres (999 dans l'image officielle) :
#   sudo mkdir -p /var/log/postgresql && sudo chown 999:999 /var/log/postgresql
