# ============================================================
# PILER - Variables d'environnement
# ============================================================
#
# Deux approches pour définir ces variables :
#
# 1. AUTOMATIQUE (recommandé) : définir sur GitHub et lancer le build
#    - Secrets GitHub : PILER_MYSQL_PASSWORD, PILER_B2_ACCOUNT_ID,
#                       PILER_B2_APPLICATION_KEY, RESTIC_PILER_PASSWORD,
#                       STORAGEBOX_PASSWORD
#    - Variables GitHub : PILER_ARCHIVE_HOST, PILER_SMTP_PORT, PILER_VERSION,
#                         PILER_B2_BUCKET, MAIN_DOMAIN,
#                         STORAGEBOX_HOST, STORAGEBOX_USERNAME, STORAGEBOX_SHARE
#    Le workflow génère ce fichier automatiquement sur le VPS.
#
# 2. MANUEL : copier ce fichier en .env sur le VPS et remplir
#    cp .env.example .env && nano .env
#
# Ne jamais commiter le fichier .env
# ===========================================================

# ---- GitHub Variables -----
ARCHIVE_HOST=archive.azteas.com    # domaine public de Piler
MAIN_DOMAIN=azteas.com             # domaine mail principal (ajouté par défaut dans Piler)
PILER_SMTP_PORT=               # port SMTP 
VERSION=1.4.8                      # version image Piler (GitHub Variable: PILER_VERSION)
ADMIN_EMAIL=admin@azteas.com
PILER_B2_BUCKET=                   # bucket Backblaze B2 dédié Piler

# ---- Hetzner Storage Box ----
STORAGEBOX_HOST=                   # ex: uXXXXXX.your-storagebox.de
STORAGEBOX_USERNAME=               # ex: uXXXXXX
STORAGEBOX_SHARE=                  # nom du partage (ex: backup)

# ---- GitHub Secrets ----
MYSQL_PASSWORD=                    # mot de passe base de données Piler
STORAGEBOX_PASSWORD=               # mot de passe Storage Box
PILER_B2_ACCOUNT_ID=               # ID compte Backblaze B2 dédié Piler
B2_ACCOUNT_KEY=                    # clé application Backblaze B2 (PILER_B2_APPLICATION_KEY)
RESTIC_PASSWORD=                   # mot de passe chiffrement backup Piler
# RESTIC_REPOSITORY est généré automatiquement : b2:PILER_B2_BUCKET:piler

# ---- SMTP (notifications fail2ban/backup) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@azteas.com
